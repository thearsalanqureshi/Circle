rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function changedOnly(fields) {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(fields);
    }

    function hasRequiredPostFields() {
      return request.resource.data.keys().hasAll([
        'id',
        'userId',
        'username',
        'userHandle',
        'text',
        'likesCount',
        'commentsCount',
        'sharesCount',
        'createdAt',
        'updatedAt',
      ]);
    }

    function isValidPostCreate(postId) {
      return hasRequiredPostFields()
        && request.resource.data.id == postId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 800
        && (!('imageBase64' in request.resource.data)
          || request.resource.data.imageBase64 == null
          || (
            request.resource.data.imageBase64 is string
            && request.resource.data.imageBase64.size() <= 410000
          ))
        && request.resource.data.likesCount == 0
        && request.resource.data.commentsCount == 0
        && request.resource.data.sharesCount == 0;
    }

    function isLikeCounterUpdate() {
      return changedOnly(['likesCount', 'updatedAt'])
        && request.resource.data.likesCount is int
        && request.resource.data.likesCount >= 0
        && (
          request.resource.data.likesCount == resource.data.likesCount + 1
          || request.resource.data.likesCount == resource.data.likesCount - 1
        );
    }

    function isCommentCounterUpdate() {
      return changedOnly(['commentsCount', 'updatedAt'])
        && request.resource.data.commentsCount is int
        && request.resource.data.commentsCount == resource.data.commentsCount + 1;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isUser(userId)
        && request.resource.data.id == userId
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0;
      allow delete: if isUser(userId);
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && isValidPostCreate(postId);
      allow update: if signedIn()
        && (isLikeCounterUpdate() || isCommentCounterUpdate());
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;

      match /likes/{userId} {
        allow read: if signedIn();
        allow create: if isUser(userId)
          && request.resource.data.userId == userId;
        allow delete: if isUser(userId);
        allow update: if false;
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.id == commentId
          && request.resource.data.postId == postId
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 500;
        allow update, delete: if signedIn()
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
